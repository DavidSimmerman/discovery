DATABASE_URL=postgres://disccovery:disccovery@127.0.0.1:5434/disccovery
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
PUBLIC_BASE_URL=http://127.0.0.1:5173
TOKEN_ENC_KEY=
SESSION_SECRET=

# Shuffle/discovery external data providers
LASTFM_API_KEY=
MUSICBRAINZ_USER_AGENT=disccovery/0.1 (your-email@example.com)

# APNs (iOS Live Activity pushes) — all optional; pushes no-op when unset.
# Without these, the Live Activity only updates while the app is foregrounded:
# no background song-change updates and no auto-end when playback stops.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_AUTH_KEY=
APNS_BUNDLE_ID=tech.simmerman.discovery
# IMPORTANT: must match the build's aps-environment. A dev build run from Xcode
# (aps-environment=development) mints SANDBOX tokens → set true. TestFlight/App
# Store builds (aps-environment=production) → set false. Mismatch = BadDeviceToken.
APNS_USE_SANDBOX=false
